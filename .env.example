# 小智 MCP 配置文件示例
# 复制此文件为 .env 并填入实际值

# 小智 MCP WebSocket URL (必填)
XIAOZHI_MCP_URL="wss://api.xiaozhi.me/mcp/?token=你的token_here"

# 桥接服务器端口 (可选，默认 18790)
XIAOZHI_PORT=18790

# Telegram 配置 (可选，用于发送消息)
TELEGRAM_BOT_TOKEN="8066651062:AAFlM9hHtXCf-iOu3tjgRVXvkqm5PFeEakU"
TELEGRAM_CHAT_ID="7597776041"

# 网络搜索 API (可选)
BRAVE_API_KEY=""

# 其他配置
NODE_ENV="production"